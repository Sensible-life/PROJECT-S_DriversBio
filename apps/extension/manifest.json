{
  "manifest_version": 3,
  "name": "DriveAI Capture",
  "version": "0.1.0",
  "description": "Capture selected study text into the DriveAI pipeline.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1:3030/*", "http://localhost:3030/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
